GC8.Shr <- GrCh.dens.2(x = zGH, cum = Scum[1:8], beta = fit8$beta,normalize = FALSE)
hist(zGH, freq=FALSE, breaks=20, main = "zGH data",ylim=c(-0.10,0.7))
hist(zGH, freq=FALSE, breaks=20, main = "zGH data",ylim=c(-0.10,0.7))
lines(zGH,GC4,col = "#FF4500",type="l", lwd = 2, lty = 2)
lines(zGH, GC4.Shr,  col = "blue", lwd = 2, lty = 2)
lines(zGH, GC8.Shr,  col = "brown", lwd = 2, lty = 2)
## k=4 ---------------------------
cums <- Scum[1:4]
fitShr <- Shr.GC(grid_x = zGH, cum = cums, weights = c(1, 1))
## check results
fitShr$beta
fitShr$feasible
fitShr$min_factor
## Fit GrCh density with betas
GC4.Shr <- GrCh.dens.2(x = zGH, cum = cums, beta = fitShr$beta,normalize = FALSE)
## Use K=8, fix skewness and kurtosis
fit8 <- Shr.GC(grid_x = zGH,cum = Scum[1:8],
fixed_orders = c(3, 4),
fixed_beta = c(1, 1)
#weights = c(1000, 1000, 1, 1, 1, 1)  ## use this for soft constraint
)
fit8$beta
fit8$feasible
fit8$min_factor
## Fit GrCh density with betas
GC8.Shr <- GrCh.dens.2(x = zGH, cum = Scum[1:8], beta = fit8$beta,normalize = FALSE)
hist(zGH, freq=FALSE, breaks=20, main = "zGH data",ylim=c(-0.10,0.7))
lines(zGH,GC4,col = "#FF4500",type="l", lwd = 2, lty = 2)
lines(zGH, GC4.Shr,  col = "blue", lwd = 2, lty = 2)
lines(zGH, GC8.Shr,  col = "brown", lwd = 2, lty = 2)
## 1. Area
trapz(zGH,Min_adapt)
trapz(zGH,MLEFit)
trapz(zGH,GC4)
trapz(zGH,GC6)
trapz(zGH,GC8)
trapz(zGH,Edge)
trapz(zGH,GC4.Shr)
trapz(zGH,GC8.Shr)  ## need to normalize
## 2. skewness
trapz(zGH,zGH^3*Min_adapt)
trapz(zGH,zGH^3*MLEFit)
trapz(zGH,zGH^3*GC4)
trapz(zGH,zGH^3*GC6)
trapz(zGH,zGH^3*GC8)
ghyp::ghyp.skewness(gh)
ghyp::ghyp.kurtosis(gh) -3
trapz(zGH,zGH^3*Edge)
trapz(zGH,zGH^3*GC4.Shr)
trapz(zGH,zGH^3*GC8.Shr)
## 3. excess kurtosis
trapz(zGH,zGH^4*Min_adapt) - 3
trapz(zGH,zGH^4*MLEFit) -3
trapz(zGH,zGH^4*GC4) -3
trapz(zGH,zGH^4*GC6) -3
trapz(zGH,zGH^4*GC8) -3
trapz(zGH,zGH^4*Edge) -3
trapz(zGH,zGH^4*GC4.Shr) -3
trapz(zGH,zGH^4*GC8.Shr) -3
Scum[1:4]
