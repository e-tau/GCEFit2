library(GCEFit)
library(MultiStatM)
library(pracma)
library(maxLik)
## -------------------------------------------------------
## GH distribution example
nalpha <- 1.8
nbeta <- -1
nlambda <- 2
param <- c(mu=0, delta= 2, alpha= nalpha, beta= nbeta, lambda=nlambda)
n=2^12
set.seed(123)
xGH <- GeneralizedHyperbolic::rghyp(n,param=param)
xGH <- sort(xGH)
zGH <-(xGH-mean(xGH))/sd(xGH)
hist(zGH)
## skewness and kurtosis
gh <- ghyp::ghyp.ad(mu=0, delta= 2, alpha= nalpha, beta= nbeta, lambda=nlambda)
ghyp::ghyp.skewness(gh)
ghyp::ghyp.kurtosis(gh) -3
## sample cumulants values
Scum <- MultiStatM::SampleMomCum(zGH,r=8,centering=FALSE,scaling=FALSE)$estCum.r
## MLE (general K)
system.time(MLE <- maxLik(LLGC2_K, data=zGH,start=c(0,1,0,3,1,2,3,4), method="BFGSR"))
MLE$estimate
round(MLE$estimate,4)
##--- 1 Min_K
##   VARIANCE - (not log-variance), general k, use cumulants
##   COINCIDES with Min.GC.extended for k=4
system.time(Min2 <- Min_K(start=MLE$estimate,cum=Scum[1:8]))
Min2$objective_value
##--- 1 Min_K
##   VARIANCE - (not log-variance), general k, use cumulants
##   COINCIDES with Min.GC.extended for k=4
system.time(Min <- Min_K(start=MLE$estimate,cum=Scum[1:8]))
Min$objective_value
Min2 <-MinE(start=MLE$estimate,cum=Scum[1:8],type="Full")
Min2$objective_value
round(cbind("f"=Min$par,"w"=Min2$par))
Min3 <- Min_K_adaptive(start=MLE$estimate, cum=Scum[1:8])
Min3$objective_value
Min3$par
Min3$cum_used
Min3$shrink_factor
## ---------------------------
##--- 1 Min_K
##   VARIANCE - (not log-variance), general k, use cumulants
##   COINCIDES with Min.GC.extended for k=4
system.time(Min <- Min_K(start=MLE$estimate,cum=Scum[1:8]))
Min$objective_value
Min_b <-MinE(start=MLE$estimate,cum=Scum[1:8],type="Full")
Min_b$objective_value
round(cbind("f"=Min$par,"w"=Min_b$par))
Min2 <- Min_K_adaptive(start=MLE$estimate, cum=Scum[1:8])
Min2$objective_value
Min2_b <-MinE(start=MLE$estimate,cum=Scum[1:8],type="Adaptive")
Min2_b$objective_value
round(cbind("f"=Min2$par,"w"=Min2_b$par))
round(cbind("f"=Min$par,"w"=Min_b$par),4)
round(cbind("f"=Min2$par,"w"=Min2_b$par),4)
K <- 8
mu.X <- Scum[1]
sig2.X <- Scum[2]
theta_1 <-  mu.X/sqrt(sig2.X) ## assumed: mu.G = 0
theta_2 <- 0                  # assumed sig2.X=sig2.G
start <- c(theta_1,theta_2 , Scum[3:K])
res <- optimize_model_BellH_K(initial_guess=start, objective_function_BellH_K, cum=Scum[3:K] )
sig2.G <- sig2.X / (1+res$par[2])
mu.G <- mu.X-sqrt(sig2.G)*res$par[1]
alpha <- c(1,0,res$par[3:K])
parGy <- c(mu.G,sig2.G, res$par[3:K])
Min_Gy <- Min_K_Gy (cum=Scum[1:K])
K <- 8
mu.X <- Scum[1]
sig2.X <- Scum[2]
theta_1 <-  mu.X/sqrt(sig2.X) ## assumed: mu.G = 0
theta_2 <- 0                  # assumed sig2.X=sig2.G
start <- c(theta_1,theta_2 , Scum[3:K])
res <- optimize_model_BellH_K(initial_guess=start, objective_function_BellH_K, cum=Scum[3:K] )
sig2.G <- sig2.X / (1+res$par[2])
mu.G <- mu.X-sqrt(sig2.G)*res$par[1]
alpha <- c(1,0,res$par[3:K])
parGy <- c(mu.G,sig2.G, res$par[3:K])
Min3_b <-MinE(cum=Scum[1:8],type="Simplified")
Min3_b$objective_value
round(cbind("OldGy"= parGy, "NewGy"= Min3_b$par),4)
Min3_b <-MinE(start=MLE$estimate, cum=Scum[1:8],type="Simplified")
Min3_b$objective_value
round(cbind("OldGy"= parGy, "NewGy"= Min3_b$par),4)
source("MLEK_MinK_new.r")
